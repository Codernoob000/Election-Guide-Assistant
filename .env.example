# ElectionBot Environment Variables
# Copy this file to .env and fill in your actual API keys

# Google Gemini API Key (required for chat functionality)
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Google Translate API Key (required for dynamic chat translation)
# WARNING: VITE_ prefixed variables are exposed in the client bundle.
# In production, proxy translation requests through a backend server.
VITE_GOOGLE_TRANSLATE_API_KEY=your_google_translate_api_key_here

# Google Analytics GA4 Measurement ID (optional)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
